{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiopspilot.dev/schemas/rule-catalog/resource-types/1.0.0",
  "title": "ResourceTypeRegistry",
  "description": "Canonical CSP-neutral resource_type vocabulary. Every entry is quoted as-is from rule.resource_type; renames require a governance PR + catalog migration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "types"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "types": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9\\-]*(\\.[a-z][a-z0-9\\-]*)*$",
          "description": "CSP-neutral identifier. Lower kebab; may contain dots as namespace separators (e.g. `compute.vm`)."
        },
        "category": {
          "type": "string",
          "enum": [
            "compute",
            "network",
            "storage",
            "database",
            "security",
            "observability",
            "governance"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "azure_arm_type": {
          "type": ["string", "null"],
          "description": "The Azure Resource Manager type path the provider adapter renders this resource to. `null` when Azure has no direct counterpart at this abstraction level."
        },
        "typical_parents": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true,
          "default": [],
          "description": "Informational only: typical `contains` parents. The authoritative graph is populated by the inventory adapter."
        }
      }
    }
  }
}
