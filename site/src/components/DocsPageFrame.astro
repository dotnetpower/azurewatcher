---
/*
 * DocsPageFrame.astro - preserves Starlight's default page frame and adds
 * the shared nebula atmosphere to the bilingual user-guide routes.
 */
import Default from "@astrojs/starlight/components/PageFrame.astro";
import NebulaBackground from "./NebulaBackground.astro";

const routeId = Astro.locals.starlightRoute.id;
const localizedRouteId = routeId.startsWith("ko/") ? routeId.slice(3) : routeId;
const hasGuidedExperience =
  localizedRouteId === "get-started" ||
  localizedRouteId.startsWith("concepts/") ||
  localizedRouteId.startsWith("guides/");
---

{hasGuidedExperience && (
  <NebulaBackground
    attachToBody
    intensity={0.68}
    speed={0.32}
    class="get-started-nebula"
  />
)}

<Default>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>