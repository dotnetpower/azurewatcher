# remediate.enable-diagnostic-settings - Terraform patch template.
#
# Referenced by rule `secret-store.diagnostic-settings-required`.
# Route AuditEvent to var.log_workspace_id.


resource "azurerm_monitor_diagnostic_setting" "${resource_id}_diag" {
  name                       = "keyvault-diag"
  target_resource_id         = azurerm_key_vault.${resource_id}.id
  log_analytics_workspace_id = var.log_workspace_id

  enabled_log {
    category = "AuditEvent"
  }
}
