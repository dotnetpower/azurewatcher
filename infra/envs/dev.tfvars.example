# ---------------------------------------------------------------
# Example dev tfvars - copy to `dev.tfvars` (git-ignored) and fill.
# Real values MUST NOT be committed (see generic-scope rules).
# ---------------------------------------------------------------

env          = "dev"
region       = "koreacentral"
region_short = "krc"

# Entra tenant that hosts the executor MI + AAD Postgres auth.
tenant_id = "00000000-0000-0000-0000-000000000000"

# Postgres admin (bootstrap only - production uses AAD auth).
postgres_admin_login    = "fdaiadmin"
postgres_admin_password = "SET-ME-VIA-VAULT"

# Core control-plane image reference (pin by digest for prod).
core_image   = "mcr.microsoft.com/azure-cli:latest"
max_replicas = 3

additional_tags = {
  environment_class = "dev"
}

# ---------------------------------------------------------------
# Private-networking deploy (policy-locked "private-everything"
# tenants). When true, the deploy MUST run from the bootstrap
# runner inside the ops VNet - the laptop cannot write KV secrets
# to a private-only vault. See infra/bootstrap/README.md.
# ---------------------------------------------------------------
# enable_private_networking = true

# Ops/hub VNet coordinates (from `terraform -chdir=infra/bootstrap output`):
#   ops_vnet_id             -> runner_vnet_id
#   ops_vnet_name           -> runner_vnet_name
#   ops_resource_group_name -> ops_resource_group_name
# runner_vnet_id          = "/subscriptions/.../virtualNetworks/vnet-fdai-ops-krc"
# runner_vnet_name        = "vnet-fdai-ops-krc"
# ops_resource_group_name = "rg-fdai-ops-krc"

