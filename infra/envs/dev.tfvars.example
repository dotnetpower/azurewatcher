# ---------------------------------------------------------------
# Example dev tfvars — copy to `dev.tfvars` (git-ignored) and fill.
# Real values MUST NOT be committed (see generic-scope rules).
# ---------------------------------------------------------------

env          = "dev"
region       = "koreacentral"
region_short = "krc"

# Entra tenant that hosts the executor MI + AAD Postgres auth.
tenant_id = "00000000-0000-0000-0000-000000000000"

# Postgres admin (bootstrap only — production uses AAD auth).
postgres_admin_login    = "aiopspilotadmin"
postgres_admin_password = "SET-ME-VIA-VAULT"

# Core control-plane image reference (pin by digest for prod).
core_image   = "mcr.microsoft.com/azure-cli:latest"
max_replicas = 3

additional_tags = {
  environment_class = "dev"
}

