<policies>
  <inbound>
    <base />
    <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized">
      <openid-config url="https://login.microsoftonline.com/${tenant_id}/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>${frontend_audience}</audience>
      </audiences>
    </validate-jwt>
    <set-variable name="fdai-backend" value="${ptu_backend_id}" />
    <set-variable name="fdai-capacity-unit" value="ptu" />
    <set-variable name="fdai-spillover" value="false" />
    <set-backend-service backend-id="${ptu_backend_id}" />
    <rewrite-uri template="/chat/completions" copy-unmatched-params="true" />
    <set-query-parameter name="api-version" exists-action="override">
      <value>${api_version}</value>
    </set-query-parameter>
    <set-body>@{
      var body = context.Request.Body.As&lt;Newtonsoft.Json.Linq.JObject&gt;(preserveContent: true);
      body.Remove("model");
      return body.ToString();
    }</set-body>
    <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
  </inbound>
  <backend>
    <retry condition="@(context.Response != null &amp;&amp; context.Response.StatusCode == 429)" count="1" interval="0" first-fast-retry="true">
      <choose>
        <when condition="@(context.Response != null &amp;&amp; context.Response.StatusCode == 429)">
          <set-variable name="fdai-backend" value="${standard_backend_id}" />
          <set-variable name="fdai-capacity-unit" value="tpm" />
          <set-variable name="fdai-spillover" value="true" />
          <set-backend-service backend-id="${standard_backend_id}" />
        </when>
      </choose>
      <forward-request buffer-request-body="true" />
    </retry>
  </backend>
  <outbound>
    <set-header name="x-fdai-model-backend" exists-action="override">
      <value>@((string)context.Variables["fdai-backend"])</value>
    </set-header>
    <set-header name="x-fdai-capacity-unit" exists-action="override">
      <value>@((string)context.Variables["fdai-capacity-unit"])</value>
    </set-header>
    <set-header name="x-fdai-spillover" exists-action="override">
      <value>@((string)context.Variables["fdai-spillover"])</value>
    </set-header>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
